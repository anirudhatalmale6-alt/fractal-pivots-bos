strlineBULLISHInput             = input.bool    (group = t02_01, title = t02__02, inline = "1", defval = true)
strlineBLCOLORInput             = input.color   (group = t02_01, title = t02__03, inline = "1", defval = color.new(color.green, 0))
strlineBLSTYLEInput             = input.string  (group = t02_01, title = t02__04, inline = "1", defval = "Solid", options = ["Solid", "Dashed", "Dotted"])
strlineBLWIDTHInput             = input.int     (group = t02_01, title = t02__05, inline = "1", defval = 1, minval = 1)
strlineBEARISHInput             = input.bool    (group = t02_01, title = t02__06, inline = "2", defval = true)
strlineBRCOLORInput             = input.color   (group = t02_01, title = t02__07, inline = "2", defval = color.new(color.red, 0))
strlineBRSTYLEInput             = input.string  (group = t02_01, title = t02__08, inline = "2", defval = "Solid", options = ["Solid", "Dashed", "Dotted"])
strlineBRWIDTHInput             = input.int     (group = t02_01, title = t02__09, inline = "2", defval = 1, minval = 1)
strZIGZAGInput                  = input.bool    (group = t02_01, title = t02__10, inline = "3", defval = true)
strzigzagCOLORInput             = input.color   (group = t02_01, title = t02__11, inline = "3", defval = color.new(color.blue, 50))
strzigzagSTYLEInput             = input.string  (group = t02_01, title = t02__12, inline = "3", defval = "Solid", options = ["Solid", "Dashed", "Dotted"])
strzigzagWIDTHInput             = input.int     (group = t02_01, title = t02__13, inline = "3", defval = 1, minval = 1)
strzigzagShowUnConfirmedInput   = input.bool    (group = t02_01, title = "Show Last Unconfirmed line", defval = false)

// => Break Lines
var string t03_01               = "Break Lines"
var string t03__01              = "New H Line  "
var string t03__02              = ""
var string t03__03              = ""
var string t03__04              = ""
var string t03__05              = "H Break Line"
var string t03__06              = ""
var string t03__07              = ""
var string t03__08              = ""
var string t03__09              = "New L Line   "
var string t03__10              = ""
var string t03__11              = ""
var string t03__12              = ""
var string t03__13              = "L Break Line "
var string t03__14              = ""
var string t03__15              = ""
var string t03__16              = ""
var string t03__17              = "Zigzag Line  "
var string t03__18              = ""
var string t03__19              = ""
var string t03__20              = ""
mjlineNHbInput                  = input.bool    (group = t03_01, title = t03__01, inline = "1", defval = true)
mjlineNHCOLORInput              = input.color   (group = t03_01, title = t03__02, inline = "1", defval = color.new(color.green, 0))
mjlineNHSTYLEInput              = input.string  (group = t03_01, title = t03__03, inline = "1", defval = "Solid", options = ["Solid", "Dashed", "Dotted"])
mjlineNHWIDTHInput              = input.int     (group = t03_01, title = t03__04, inline = "1", defval = 1, minval = 1)
mjlineBHbInput                  = input.bool    (group = t03_01, title = t03__05, inline = "2", defval = true)
mjlineBHCOLORInput              = input.color   (group = t03_01, title = t03__06, inline = "2", defval = color.new(color.green, 0))
mjlineBHSTYLEInput              = input.string  (group = t03_01, title = t03__07, inline = "2", defval = "Dashed", options = ["Solid", "Dashed", "Dotted"])
mjlineBHWIDTHInput              = input.int     (group = t03_01, title = t03__08, inline = "2", defval = 1, minval = 1)
mjlineNLbInput                  = input.bool    (group = t03_01, title = t03__09, inline = "3", defval = true)
mjlineNLCOLORInput              = input.color   (group = t03_01, title = t03__10, inline = "3", defval = color.new(color.red, 0))
mjlineNLSTYLEInput              = input.string  (group = t03_01, title = t03__11, inline = "3", defval = "Solid", options = ["Solid", "Dashed", "Dotted"])
mjlineNLWIDTHInput              = input.int     (group = t03_01, title = t03__12, inline = "3", defval = 1, minval = 1)
mjlineBLbInput                  = input.bool    (group = t03_01, title = t03__13, inline = "4", defval = true)
mjlineBLCOLORInput              = input.color   (group = t03_01, title = t03__14, inline = "4", defval = color.new(color.red, 0))
mjlineBLSTYLEInput              = input.string  (group = t03_01, title = t03__15, inline = "4", defval = "Dashed", options = ["Solid", "Dashed", "Dotted"])
mjlineBLWIDTHInput              = input.int     (group = t03_01, title = t03__16, inline = "4", defval = 1, minval = 1)
mjZIGZAGbInput                  = input.bool    (group = t03_01, title = t03__17, inline = "5", defval = true)
mjzigzagCOLORInput              = input.color   (group = t03_01, title = t03__18, inline = "5", defval = color.new(color.orange, 50))
mjzigzagSTYLEInput              = input.string  (group = t03_01, title = t03__19, inline = "5", defval = "Solid", options = ["Solid", "Dashed", "Dotted"])
