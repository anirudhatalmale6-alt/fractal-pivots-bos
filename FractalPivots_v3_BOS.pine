// ---------- CALCULATIONS
// => Type
type structure
    string  cond
    float   pivot
    int     pivotindex
    int     pivottime
    line    lnbr
    line    lnzigzag
    label   lbpivot

type major
    string  cond
    float   pivot
    int     pivotindex
    int     pivottime
    line    lnzigzag

// => Functions
f_breakline(_linehigh, _linelow, _x1, _x2, _high, _low) =>
    if strlineBEARISHInput
        line.set_xy1(_linehigh, _x1, _high)
        line.set_xy2(_linehigh, _x2, _high)
    if strlineBULLISHInput
        line.set_xy1(_linelow, _x1, _low)
        line.set_xy2(_linelow, _x2, _low)

f_linestyle(_style) =>
    st = switch _style
        "Solid"     => line.style_solid
        "Dotted"    => line.style_dotted
        "Dashed"    => line.style_dashed

raw_lowest(_indexstart) =>
    lowestval  = low
    lowestind  = bar_index
    for i = (bar_index - 1) to _indexstart
        if low[bar_index - i] <= lowestval
            lowestval  := low[bar_index - i]
            lowestind  := i
    [lowestval, lowestind]

raw_highest(_indexstart) =>
    highestval  = high
    highestind  = bar_index
    for i = (bar_index - 1) to _indexstart
        if high[bar_index - i] >= highestval
            highestval  := high[bar_index - i]
            highestind  := i
    [highestval, highestind]

f_highest(_indexstart) =>
    float   highestval = na
    int     highestind = na
    [lowest_value, ind] = raw_lowest(_indexstart)
    if(lowest_value==low and close>open)
        highestval  := high[1]
        highestind  := bar_index-1
    else
        highestval  := high
        highestind  := bar_index
    for i = (bar_index - 1) to _indexstart
        if high[bar_index - i] >= highestval
            highestval  := high[bar_index - i]
            highestind  := i
    [highestval, highestind]

f_lowest(_indexstart) =>
    float lowestval = na
    int lowestind = na
    [highest_value, ind]= raw_highest(_indexstart)
    if(highest_value==high and close<open)
        lowestval  := low[1]
        lowestind  := bar_index-1
    else
        lowestval  := low
        lowestind  := bar_index
    for i = (bar_index - 1) to _indexstart
        if low[bar_index - i] <= lowestval
            lowestval  := low[bar_index - i]
            lowestind  := i
    [lowestval, lowestind]

f_zigzagmaj(_mjarr) =>
    if mjZIGZAGbInput and array.size(_mjarr) >= 2
        typepre             = array.get(_mjarr, array.size(_mjarr) - 2)
        typecur             = array.get(_mjarr, array.size(_mjarr) - 1)
        x1                  = typepre.pivottime
        y1                  = typepre.pivot
        x2                  = typecur.pivottime
        y2                  = typecur.pivot
        typecur.lnzigzag    := line.new(x1, y1, x2, y2, xloc = xloc.bar_time,  extend = extend.none, color = mjzigzagCOLORInput, style = f_linestyle(mjzigzagSTYLEInput), width = mjzigzagWIDTHInput)

// => LTF Likidite Tespit Fonksiyonu — ANA INDIKATÖR MANTIGI (v37+)
// 1M'de AYNI minor + major yapi tespiti calisir
// Bu sayede 1M major kirilimlar (MSS) tam olarak eslestir
f_ltfDetect() =>
    // --- MINOR STRUCTURE (ana indikatörle birebir ayni) ---
    var string sc = ""
    var float sCH = na
    var float sCL = na
    var int sCI = na
    var int sSize = 0
    // Son pivot takibi (array yerine degiskenler)
    var string lpC = ""   // lastPivotCond
    var float lpV = na    // lastPivotValue
    var int lpI = na      // lastPivotIndex
    var string ppC = ""   // prevPivotCond
    var float ppV = na
    var int ppI = na
    sBull = false
    sBull2 = false
    sBear = false
    sBear2 = false
    if sc == ""
        sCH := high
        sCL := low
        sCI := bar_index
        sc := "First"
    if sc == "First" and barstate.isconfirmed
        if high > sCH and close >= open
            sc := "Bullish"
            sBull := true
        if low < sCL and close < open
            sc := "Bearish"
            sBear := true
    if sc == "Bullish" and sBull == false and barstate.isconfirmed
        if high > sCH and low < sCL
            if close >= open
                sc := "Bearish"
                sBear := true
                sBear2 := true
            else
                sCH := high
                sCL := low
                sCI := bar_index
                sc := "Bearish"
                sBear := true
        else if low < sCL
            sc := "Bearish"
            sBear := true
        else if high > sCH
            sCH := high
            sCL := low
            sCI := bar_index
    if sc == "Bearish" and sBear == false and barstate.isconfirmed
        if high > sCH and low < sCL
            if close >= open
                sCH := high
                sCL := low
                sCI := bar_index
                sc := "Bullish"
                sBull := true
            else
                sc := "Bullish"
                sBull := true
                sBull2 := true
        else if high > sCH
            sc := "Bullish"
            sBull := true
        else if low < sCL
            sCH := high
            sCL := low
            sCI := bar_index
    // Add Low Level (Bullish pivot)
    if sBull
        ppC := lpC
        ppV := lpV
        ppI := lpI
        lpC := "Low"
        lpV := sCL
        lpI := sCI
        sCH := high
        sCL := low
        sCI := bar_index
        sSize += 1
        if sBull2
            sc := "Bearish"
            ppC := lpC
            ppV := lpV
            ppI := lpI
            lpC := "High"
            lpV := sCH
            lpI := sCI
            sSize += 1
    // Add High Level (Bearish pivot)
    if sBear
        ppC := lpC
        ppV := lpV
        ppI := lpI
        lpC := "High"
        lpV := sCH
        lpI := sCI
        sCH := high
        sCL := low
        sCI := bar_index
        sSize += 1
        if sBear2
            sc := "Bullish"
            ppC := lpC
            ppV := lpV
            ppI := lpI
            lpC := "Low"
            lpV := sCL
            lpI := sCI
            sSize += 1
    // --- MAJOR STRUCTURE (ana indikatörle birebir ayni) ---
    var string mDir = ""
    var float mHV = na     // mjHHVal
    var int mHI = na       // mjHHInd
    var float mLV = na     // mjLLVal
    var int mLI = na       // mjLLInd
    var bool mHBr = false  // mjHighLineBr
    var bool mLBr = false  // mjLowLineBr
    var int mHBrI = na     // mjHighLineBrInd
    var int mLBrI = na     // mjLowLineBrInd
    mLong = false
    mShort = false
    // Ilk yon belirleme
    if mDir == "" and sSize > 0
        if sSize != sSize[1]
            if lpC == "High" and na(mHV)
                mHV := lpV
                mHI := lpI
                mHBr := false
            if lpC == "Low" and na(mLV)
                mLV := lpV
                mLI := lpI
                mLBr := false
        if na(mHV) == false and high > mHV
            [lv, li] = f_lowest(mHI)
            mDir := "Long"
            mHBr := true
            mHBrI := bar_index
            mLong := true
            mLV := lv
            mLI := li
        if na(mLV) == false and low < mLV
            [hv, hi2] = f_highest(mLI)
            mDir := "Short"
            mLBr := true
            mLBrI := bar_index
            mShort := true
            mHV := hv
            mHI := hi2
    // Short trend
    if mDir == "Short"
        np = false
        // Block 1: pivot check (strSize[2] lookback)
        if mLBr and sSize != sSize[2]
            if lpC == "Low" and lpI >= mLBrI
                mLV := lpV
                mLI := lpI
                mLBr := false
                np := true
            if sSize - sSize[1] == 2
                if (lpC == "Low" and lpI >= mLBrI) or (ppC == "Low" and ppI >= mLBrI)
                    tV = lpC == "Low" ? lpV : ppV
                    tI = lpC == "Low" ? lpI : ppI
                    mLV := tV
                    mLI := tI
                    mLBr := false
                    np := true
        // Break check
        if mLBr == false and low < mLV
            [hv, hi2] = f_highest(mLI)
            mLBr := true
            mHBr := false
            mLBrI := bar_index
            mHV := hv
            mHI := hi2
        else if mHBr == false and high > mHV
            [lv, li] = f_lowest(mHI)
            mDir := "Long"
            mHBr := true
            mHBrI := bar_index
            mLBr := false
            mLong := true
            mLV := lv
            mLI := li
        // Block 2: post-break pivot check (1-bar lookback)
        if np == false and mLBr and sSize != sSize[1]
            nP2 = sSize - sSize[1]
            if nP2 == 1
                if lpC == "Low" and lpI >= mLBrI
                    mLV := lpV
                    mLI := lpI
                    mLBr := false
            if nP2 == 2
                if (lpC == "Low" and lpI >= mLBrI) or (ppC == "Low" and ppI >= mLBrI)
                    tV = lpC == "Low" ? lpV : ppV
                    tI = lpC == "Low" ? lpI : ppI
                    mLV := tV
                    mLI := tI
                    mLBr := false
    // Long trend
    if mDir == "Long"
        np = false
        // Block 1: pivot check (1-bar lookback — matching main indicator Long code)
        if mHBr and sSize != sSize[1]
            nP2 = sSize - sSize[1]
            if nP2 == 1
                if lpC == "High" and lpI >= mHBrI
                    mHV := lpV
                    mHI := lpI
                    mHBr := false
                    np := true
            if nP2 == 2
                if (lpC == "High" and lpI >= mHBrI) or (ppC == "High" and ppI >= mHBrI)
                    tV = lpC == "High" ? lpV : ppV
                    tI = lpC == "High" ? lpI : ppI
                    mHV := tV
                    mHI := tI
                    mHBr := false
                    np := true
        // Break check
        if mHBr == false and high > mHV
            [lv, li] = f_lowest(mHI)
            mHBr := true
            mLBr := false
            mHBrI := bar_index
            mLV := lv
            mLI := li
        else if mLBr == false and low < mLV
            [hv, hi2] = f_highest(mLI)
            mDir := "Short"
            mLBr := true
            mHBr := false
            mShort := true
            mLBrI := bar_index
            mHV := hv
            mHI := hi2
        // Block 2: post-break pivot check
        if np == false and mHBr and sSize != sSize[1]
            nP2 = sSize - sSize[1]
            if nP2 == 1
                if lpC == "High" and lpI >= mHBrI
                    mHV := lpV
                    mHI := lpI
                    mHBr := false
            if nP2 == 2
                if (lpC == "High" and lpI >= mHBrI) or (ppC == "High" and ppI >= mHBrI)
                    tV = lpC == "High" ? lpV : ppV
                    tI = lpC == "High" ? lpI : ppI
                    mHV := tV
                    mHI := tI
                    mHBr := false
    // MSS sinyalleri say (mLong = Bull MSS, mShort = Bear MSS)
    var int bullSignalCnt = 0
    var int bearSignalCnt = 0
    if mLong
        bullSignalCnt += 1
    if mShort
        bearSignalCnt += 1
    [bullSignalCnt, bearSignalCnt]

// => LTF Zaman Dilimi Eslestirmesi
lowerTF = switch timeframe.period
    "1S"  => "1S"
    "5S"  => "1S"
    "15S" => "5S"
    "30S" => "15S"
    "1"   => "15S"
    "5"   => "1"
    "15"  => "5"
    "60"  => "15"
    => timeframe.period
supportedTF = (timeframe.period == "1S" or timeframe.period == "5S" or timeframe.period == "15S" or timeframe.period == "30S" or timeframe.period == "1" or timeframe.period == "5" or timeframe.period == "15" or timeframe.period == "60")
// Gercek alt zaman dilimi var mi? (1S icin LTF=HTF, kalite BOS devre disi)
hasRealLTF = lowerTF != timeframe.period

// => LTF Sinyal Alma (request.security)
[ltfBullCnt, ltfBearCnt] = request.security(syminfo.tickerid, lowerTF, f_ltfDetect())
var int prevLtfBullCnt = 0
var int prevLtfBearCnt = 0
ltfBullSignal = supportedTF and not na(ltfBullCnt) and ltfBullCnt > prevLtfBullCnt
ltfBearSignal = supportedTF and not na(ltfBearCnt) and ltfBearCnt > prevLtfBearCnt
if not na(ltfBullCnt)
    prevLtfBullCnt := ltfBullCnt
if not na(ltfBearCnt)
    prevLtfBearCnt := ltfBearCnt

// v39: Iki asamali kalite bayragi — oncucu tuketimli + karsilikli ozel bayraklar
// Kaliteli BOS icin 1M'de: once likidite alinir (ters yone MSS), sonra kirilim gelir (geri MSS)
// Ornek bearish kaliteli: once Bull MSS (likidite yukari), sonra Bear MSS (kirilim asagi)
var bool ltfBullReady = false
var bool ltfBearReady = false
var int ltfBullReadyBar = 0
var int ltfBearReadyBar = 0

var bool ltfBullPrecursor = false  // Bull MSS oldu (bearish kaliteli icin likidite oncusu)
var bool ltfBearPrecursor = false  // Bear MSS oldu (bullish kaliteli icin likidite oncusu)

if ltfBullSignal
    // Bull MSS = 1M yukari kirilim (bearish kaliteli icin oncu = likidite yukari)
    ltfBullPrecursor := true
    // Bullish kaliteli BOS icin: once Bear likidite + sonra Bull MSS
    if ltfBearPrecursor
        ltfBullReady := true
        ltfBullReadyBar := bar_index
        ltfBearReady := false       // karsilikli ozel: sadece 1 yon kaliteli olabilir
        ltfBearPrecursor := false   // oncucu tuket — tekrar kullanilmasin
if ltfBearSignal
    // Bear MSS = 1M asagi kirilim (bullish kaliteli icin oncu = likidite asagi)
    ltfBearPrecursor := true
    // Bearish kaliteli BOS icin: once Bull likidite + sonra Bear MSS
    if ltfBullPrecursor
        ltfBearReady := true
        ltfBearReadyBar := bar_index
        ltfBullReady := false       // karsilikli ozel: sadece 1 yon kaliteli olabilir
        ltfBullPrecursor := false   // oncucu tuket — tekrar kullanilmasin
// Zaman asimi — 30 HTF bar (~150 dk @ 5M)
if ltfBullReady and bar_index - ltfBullReadyBar > 30
    ltfBullReady := false
if ltfBearReady and bar_index - ltfBearReadyBar > 30
    ltfBearReady := false

// BOS Sayaclari
var int rawBOSCount     = 0
var int qualityBOSCount = 0

// => Fractal Pivot
var string      strCond             = ""
var line        strHighLine         = line.new(na, na, na, na, xloc = xloc.bar_index, extend = extend.none, color = strlineBRCOLORInput, style = f_linestyle(strlineBRSTYLEInput), width = strlineBRWIDTHInput)
var line        strLowLine          = line.new(na, na, na, na, xloc = xloc.bar_index, extend = extend.none, color = strlineBLCOLORInput, style = f_linestyle(strlineBLSTYLEInput), width = strlineBLWIDTHInput)
var line        strZigzagLine       = line.new(na, na, na, na, xloc = xloc.bar_time,  extend = extend.none, color = strzigzagCOLORInput, style = f_linestyle(strzigzagSTYLEInput), width = strzigzagWIDTHInput)
var structure[] strARR              = array.new<structure>()
var float       strCandleHigh       = na
var float       strCandleLow        = na
var int         strCandleTime       = na
var int         strCandleIndex      = na
var float       strPivHighest       = na
var int         strPivHighestIndex  = na
var int         strPivHighestTime   = na
var float       strPivLowest        = na
var int         strPivLowestIndex   = na
var int         strPivLowestTime    = na
var int         strSize             = 0

strBullish  = false
strBullish2 = false
strBearish  = false
strBearish2 = false

// First Pivot
if (strtimeACTIVEbInput ? time >= strTIMEInput : true)
    if strCond == ""
        strCandleHigh       := high
        strCandleLow        := low
        strCandleTime       := time
        strCandleIndex      := bar_index
        strCond             := "First"
        strPivHighest       := high
        strPivLowest        := low
        strPivHighestTime   := time
        strPivLowestTime    := time
        strPivHighestIndex  := bar_index
        strPivLowestIndex   := bar_index
        f_breakline(strHighLine, strLowLine, strCandleIndex, strCandleIndex + 1, strCandleHigh, strCandleLow)
    // First Break
    if strCond == "First" and barstate.isconfirmed
        if high > strCandleHigh and close >= open
            strCond         := "Bullish"
            strBullish      := true
        if low < strCandleLow and close < open
            strCond         := "Bearish"
            strBearish      := true

// Bullish
if strCond == "Bullish" and strBullish == false and barstate.isconfirmed
    // if Outsider high and low is broken at the same time
    if high > strCandleHigh and low < strCandleLow
        // If candle is green, low to high
        if close >= open
            strCond         := "Bearish"
            strBearish      := true
            strBearish2     := true
        // If candle is red, High to low
        else
            strCandleHigh   := high
            strCandleLow    := low
            strCandleTime   := time
            strCandleIndex  := bar_index
            strCond         := "Bearish"
            strBearish      := true
    // Outsider is broken
    else if low < strCandleLow
        strCond         := "Bearish"
        strBearish      := true
    // New outsider
    else if high > strCandleHigh
        strCandleHigh   := high
        strCandleLow    := low
        strCandleTime   := time
        strCandleIndex  := bar_index
        f_breakline(strHighLine, strLowLine, strCandleIndex, strCandleIndex + 1, strCandleHigh, strCandleLow)

// Bearish
if strCond == "Bearish" and strBearish == false and barstate.isconfirmed
    // if Outsider high and low is broken at the same time
    if high > strCandleHigh and low < strCandleLow
        // If candle is green, low to high
        if close >= open
            strCandleHigh   := high
            strCandleLow    := low
            strCandleTime   := time
            strCandleIndex  := bar_index
            strCond         := "Bullish"
            strBullish      := true
        // If candle is red, High to low
        else
            strCond         := "Bullish"
            strBullish      := true
            strBullish2     := true
    // Outsider is broken
    else if high > strCandleHigh
        strCond         := "Bullish"
        strBullish      := true
    // New outsider
    else if low < strCandleLow
        strCandleHigh   := high
        strCandleLow    := low
        strCandleTime   := time
        strCandleIndex  := bar_index
        f_breakline(strHighLine, strLowLine, strCandleIndex, strCandleIndex + 1, strCandleHigh, strCandleLow)

if strBearish
    strPivHighest       := strCandleHigh
    strPivHighestIndex  := strCandleIndex
    strPivHighestTime   := strCandleTime
if strBullish
    strPivLowest        := strCandleLow
    strPivLowestIndex   := strCandleIndex
    strPivLowestTime    := strCandleTime

if strlineBEARISHInput
    line.set_x2(strHighLine, bar_index + 1)
if strlineBULLISHInput
    line.set_x2(strLowLine, bar_index + 1)
if strZIGZAGInput
    line.set_xy2(strZigzagLine, strCandleTime, (strCond == "Bullish" ? strCandleHigh : strCandleLow))

if (strBullish or strBearish)
    line.set_x2(strHighLine, bar_index)
    line.set_x2(strLowLine, bar_index)
    if strZIGZAGInput
        if strBullish
            line.set_xy1(strZigzagLine, strPivLowestTime, strPivLowest)
            line.set_xy2(strZigzagLine, strCandleTime, strCandleHigh)
        if strBearish
            line.set_xy1(strZigzagLine, strPivHighestTime, strPivHighest)
            line.set_xy2(strZigzagLine, strCandleTime, strCandleLow)

// Add Low Level
if strBullish
    typenew = structure.new("Low", strCandleLow, strCandleIndex, strCandleTime)
    if strlineBEARISHInput
        typenew.lnbr        := line.copy(strHighLine)
    if strZIGZAGInput and array.size(strARR) > 0
        typelast            = array.last(strARR)
        x1                  = typelast.pivottime
        y1                  = typelast.pivot
        typenew.lnzigzag    := line.new(x1, y1, strCandleTime, strCandleLow, xloc = xloc.bar_time, extend = extend.none, color = strzigzagCOLORInput, style = f_linestyle(strzigzagSTYLEInput), width = strzigzagWIDTHInput)
    if strpivotSTYLEInput != "None"
        txt                 = strpivotSTYLEInput == "Label" ? "L" : "🔴"
        lbcolor             = strpivotSTYLEInput == "Label" ? color.red : color.new(color.white, 100)
        typenew.lbpivot     := label.new(strCandleTime, strCandleLow, txt, xloc = xloc.bar_time, color = lbcolor, style = label.style_label_up, textcolor = color.white, size = size.tiny)
    array.push(strARR, typenew)
    strCandleHigh           := high
    strCandleLow            := low
    strCandleTime           := time
    strCandleIndex          := bar_index
    strSize                 := strSize + 1
    f_breakline(strHighLine, strLowLine, strCandleIndex, strCandleIndex + 1, strCandleHigh, strCandleLow)
    if strBullish2
        strCond := "Bearish"
        typenew := structure.new("High", strCandleHigh, strCandleIndex, strCandleTime)
        if strZIGZAGInput and array.size(strARR) > 0
            typelast            = array.last(strARR)
            x1                  = typelast.pivottime
            y1                  = typelast.pivot
            typenew.lnzigzag    := line.new(x1, y1, strCandleTime, strCandleHigh, xloc = xloc.bar_time, extend = extend.none, color = strzigzagCOLORInput, style = f_linestyle(strzigzagSTYLEInput), width = strzigzagWIDTHInput)
        if strpivotSTYLEInput != "None"
            txt                 = strpivotSTYLEInput == "Label" ? "H" : "🟢"
            lbcolor             = strpivotSTYLEInput == "Label" ? color.green : color.new(color.white, 100)
            typenew.lbpivot     := label.new(strCandleTime, strCandleHigh, txt, xloc = xloc.bar_time, color = lbcolor, style = label.style_label_down, textcolor = color.white, size = size.tiny)
        array.push(strARR, typenew)
        strSize := strSize + 1
        x1      = strCandleTime
        y1      = strCandleHigh
        line.set_xy1(strZigzagLine, x1, y1)
        line.set_xy2(strZigzagLine, strCandleTime, strCandleLow)
        strPivHighest       := strCandleHigh
        strPivHighestIndex  := strCandleIndex
        strPivHighestTime   := strCandleTime

// Add High Level
if strBearish
    typenew = structure.new("High", strCandleHigh, strCandleIndex, strCandleTime)
    if strlineBULLISHInput
        typenew.lnbr        := line.copy(strLowLine)
    if strZIGZAGInput and array.size(strARR) > 0
        typelast            = array.last(strARR)
        x1                  = typelast.pivottime
        y1                  = typelast.pivot
        typenew.lnzigzag    := line.new(x1, y1, strCandleTime, strCandleHigh, xloc = xloc.bar_time, extend = extend.none, color = strzigzagCOLORInput, style = f_linestyle(strzigzagSTYLEInput), width = strzigzagWIDTHInput)
    if strpivotSTYLEInput != "None"
        txt                 = strpivotSTYLEInput == "Label" ? "H" : "🟢"
        lbcolor             = strpivotSTYLEInput == "Label" ? color.green : color.new(color.white, 100)
        typenew.lbpivot     := label.new(strCandleTime, strCandleHigh, txt, xloc = xloc.bar_time, color = lbcolor, style = label.style_label_down, textcolor = color.white, size = size.tiny)
    array.push(strARR, typenew)
    strSize                 := strSize + 1
    strCandleHigh           := high
    strCandleLow            := low
    strCandleTime           := time
    strCandleIndex          := bar_index
    f_breakline(strHighLine, strLowLine, strCandleIndex, strCandleIndex + 1, strCandleHigh, strCandleLow)
    if strBearish2
        strCond := "Bullish"
        typenew := structure.new("Low", strCandleLow, strCandleIndex, strCandleTime)
        if strZIGZAGInput and array.size(strARR) > 0
            typelast            = array.last(strARR)
            x1                  = typelast.pivottime
            y1                  = typelast.pivot
            typenew.lnzigzag    := line.new(x1, y1, strCandleTime, strCandleLow, xloc = xloc.bar_time, extend = extend.none, color = strzigzagCOLORInput, style = f_linestyle(strzigzagSTYLEInput), width = strzigzagWIDTHInput)
        if strpivotSTYLEInput != "None"
            txt                 = strpivotSTYLEInput == "Label" ? "L" : "🔴"
            lbcolor             = strpivotSTYLEInput == "Label" ? color.red : color.new(color.white, 100)
            typenew.lbpivot     := label.new(strCandleTime, strCandleLow, txt, xloc = xloc.bar_time, color = lbcolor, style = label.style_label_up, textcolor = color.white, size = size.tiny)
        array.push(strARR, typenew)
        strSize := strSize + 1
        x1      = strCandleTime
        y1      = strCandleLow
        line.set_xy1(strZigzagLine, x1, y1)
        line.set_xy2(strZigzagLine, strCandleTime, strCandleHigh)
        strPivLowest        := strCandleLow
        strPivLowestIndex   := strCandleIndex
        strPivLowestTime    := strCandleTime

// => Major Lines
var string  mjDir           = ""
var float   mjHHVal         = na
var int     mjHHInd         = na
var float   mjLLVal         = na
var int     mjLLInd         = na
var line    mjHighLine      = line.new(na, na, na, na, xloc = xloc.bar_index, extend = extend.none, color = mjlineNHCOLORInput,  style = f_linestyle(mjlineNHSTYLEInput),  width = mjlineNHWIDTHInput)
var line    mjLowLine       = line.new(na, na, na, na, xloc = xloc.bar_index, extend = extend.none, color = mjlineNLCOLORInput,  style = f_linestyle(mjlineNLSTYLEInput),  width = mjlineNLWIDTHInput)
var bool    mjHighLineBr    = false
var bool    mjLowLineBr     = false
var int     mjHighLineBrInd = na
var int     mjLowLineBrInd  = na

var major[] mjARR           = array.new<major>()

mjLong        = false
mjShort       = false
mjHH          = false
mjLL          = false

if mjDir == "" and array.size(strARR) > 0
    if array.size(strARR) != array.size(strARR[1])
        typenew = array.last(strARR)
        cond    = typenew.cond
        if cond == "High" and na(mjHHVal)
            mjHHVal         := typenew.pivot
            mjHHInd         := typenew.pivotindex
            mjHighLineBr    := false
            majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
            array.push(mjARR, majornew)
            f_zigzagmaj(mjARR)
        if cond == "Low" and na(mjLLVal)
            mjLLVal         := typenew.pivot
            mjLLInd         := typenew.pivotindex
            mjLowLineBr     := false
            majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
            array.push(mjARR, majornew)
            f_zigzagmaj(mjARR)
    if na(mjHHVal) == false and high > mjHHVal
        [lowestval, lowestind] = f_lowest(mjHHInd)
        mjDir           := "Long"
        mjHighLineBr    := true
        mjHighLineBrInd := bar_index
        mjLong          := true
        mjLLVal         := lowestval
        mjLLInd         := lowestind
        if mjlineBLbInput
            mjHighLine   := line.new(time[bar_index - mjHHInd], mjHHVal, time, mjHHVal, xloc = xloc.bar_time, extend = extend.none, color = mjlineBLCOLORInput,  style = f_linestyle(mjlineBLSTYLEInput),  width = mjlineBLWIDTHInput)
        majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
        array.push(mjARR, majornew)
        f_zigzagmaj(mjARR)
    if na(mjLLVal) == false and low < mjLLVal
        [highestval, highestind] = f_highest(mjLLInd)
        mjDir           := "Short"
        mjLowLineBr     := true
        mjLowLineBrInd  := bar_index
        mjShort         := true
        mjHHVal         := highestval
        mjHHInd         := highestind
        if mjlineBHbInput
            mjLowLine   := line.new(time[bar_index - mjLLInd], mjLLVal, time, mjLLVal, xloc = xloc.bar_time, extend = extend.none, color = mjlineBHCOLORInput,  style = f_linestyle(mjlineBHSTYLEInput),  width = mjlineBHWIDTHInput)
        majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
        array.push(mjARR, majornew)
        f_zigzagmaj(mjARR)

if mjDir == "Short"
    newpivot = false
    if mjLowLineBr and strSize != strSize[2]
        sizecur = array.size(strARR)
        sizepre = array.size(strARR[1])
        if true
            typenew = array.last(strARR)
            if  typenew.cond == "Low" and typenew.pivotindex >= mjLowLineBrInd
                mjLLVal         := typenew.pivot
                mjLLInd         := typenew.pivotindex
                mjLowLineBr     := false
                newpivot        := true
                majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)
        if (sizecur - sizepre) == 2
            typelast    = array.last(strARR)
            typepre     = array.get(strARR, array.size(strARR) - 2)
            if (typelast.cond == "Low" and typelast.pivotindex >= mjLowLineBrInd) or (typepre.cond == "Low" and typepre.pivotindex >= mjLowLineBrInd)
                typel       = typelast.cond == "Low" ? typelast : typepre
                mjLLVal     := typel.pivot
                mjLLInd     := typel.pivotindex
                mjLowLineBr := false
                newpivot    := true
                majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)
    if mjLowLineBr == false and low < mjLLVal
        [highestval, highestind] = f_highest(mjLLInd)
        mjLowLineBr     := true
        mjHighLineBr    := false
        mjLL            := true
        mjLowLineBrInd  := bar_index
        mjHHVal         := highestval
        mjHHInd         := highestind
        if mjlineNLbInput
            mjLowLine   := line.new(time[bar_index - mjLLInd], mjLLVal, time, mjLLVal, xloc = xloc.bar_time, extend = extend.none, color = mjlineNLCOLORInput,  style = f_linestyle(mjlineNLSTYLEInput),  width = mjlineNLWIDTHInput)
        majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
        array.push(mjARR, majornew)
        f_zigzagmaj(mjARR)
    else if mjHighLineBr == false and high > mjHHVal
        [lowestval, lowestind] = f_lowest(mjHHInd)
        mjDir           := "Long"
        mjHighLineBr    := true
        mjHighLineBrInd := bar_index
        mjLowLineBr     := false
        mjLong          := true
        mjLLVal         := lowestval
        mjLLInd         := lowestind
        if mjlineBLbInput
            mjHighLine   := line.new(time[bar_index - mjHHInd], mjHHVal, time, mjHHVal, xloc = xloc.bar_time, extend = extend.none, color = mjlineBLCOLORInput,  style = f_linestyle(mjlineBLSTYLEInput),  width = mjlineBLWIDTHInput)
        majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
        array.push(mjARR, majornew)
        f_zigzagmaj(mjARR)
    if newpivot == false and mjLowLineBr and array.size(strARR) != array.size(strARR[1])
        sizecur = array.size(strARR)
        sizepre = array.size(strARR[1])
        if (sizecur - sizepre) == 1
            typenew = array.last(strARR)
            if typenew.cond == "Low" and typenew.pivotindex >= mjLowLineBrInd
                mjLLVal         := typenew.pivot
                mjLLInd         := typenew.pivotindex
                mjLowLineBr     := false
                majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)
        if (sizecur - sizepre) == 2
            typelast    = array.last(strARR)
            typepre     = array.get(strARR, array.size(strARR) - 2)
            if (typelast.cond == "Low" and typelast.pivotindex >= mjLowLineBrInd) or (typepre.cond == "Low" and typepre.pivotindex >= mjLowLineBrInd)
                typel       = typelast.cond == "Low" ? typelast : typepre
                mjLLVal     := typel.pivot
                mjLLInd     := typel.pivotindex
                mjLowLineBr := false
                majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)

if mjDir == "Long"
    newpivot = false
    if mjHighLineBr and array.size(strARR) != array.size(strARR[1])
        sizecur = array.size(strARR)
        sizepre = array.size(strARR[1])
        if (sizecur - sizepre) == 1
            typenew = array.last(strARR)
            if typenew.cond == "High" and typenew.pivotindex >= mjHighLineBrInd
                mjHHVal         := typenew.pivot
                mjHHInd         := typenew.pivotindex
                mjHighLineBr    := false
                newpivot        := true
                majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)
        if (sizecur - sizepre) == 2
            typelast        = array.last(strARR)
            typepre         = array.get(strARR, array.size(strARR) - 2)
            if (typelast.cond == "High" and typelast.pivotindex >= mjHighLineBrInd) or (typepre.cond == "High" and typepre.pivotindex >= mjHighLineBrInd)
                typeh           = typelast.cond == "High" ? typelast : typepre
                mjHHVal         := typeh.pivot
                mjHHInd         := typeh.pivotindex
                mjHighLineBr    := false
                newpivot        := true
                majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)
    if mjHighLineBr == false and high > mjHHVal
        [lowestval, lowestind] = f_lowest(mjHHInd)
        mjHighLineBr    := true
        mjLowLineBr     := false
        mjHH            := true
        mjHighLineBrInd := bar_index
        mjLLVal         := lowestval
        mjLLInd         := lowestind
        if mjlineNHbInput
            mjHighLine   := line.new(time[bar_index - mjHHInd], mjHHVal, time, mjHHVal, xloc = xloc.bar_time, extend = extend.none, color = mjlineNHCOLORInput,  style = f_linestyle(mjlineNHSTYLEInput),  width = mjlineNHWIDTHInput)
        majornew = major.new("Low", mjLLVal, mjLLInd, time[bar_index - mjLLInd])
        array.push(mjARR, majornew)
        f_zigzagmaj(mjARR)
    else if mjLowLineBr == false and low < mjLLVal
        [highestval, highestind] = f_highest(mjLLInd)
        mjDir           := "Short"
        mjLowLineBr     := true
        mjHighLineBr    := false
        mjShort         := true
        mjLowLineBrInd  := bar_index
        mjHHVal         := highestval
        mjHHInd         := highestind
        if mjlineBHbInput
            mjLowLine   := line.new(time[bar_index - mjLLInd], mjLLVal, time, mjLLVal, xloc = xloc.bar_time, extend = extend.none, color = mjlineBHCOLORInput,  style = f_linestyle(mjlineBHSTYLEInput),  width = mjlineBHWIDTHInput)
        majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
        array.push(mjARR, majornew)
        f_zigzagmaj(mjARR)
    if newpivot == false and mjHighLineBr and array.size(strARR) != array.size(strARR[1])
        sizecur = array.size(strARR)
        sizepre = array.size(strARR[1])
        if (sizecur - sizepre) == 1
            typenew = array.last(strARR)
            if typenew.cond == "High" and typenew.pivotindex >= mjHighLineBrInd
                mjHHVal         := typenew.pivot
                mjHHInd         := typenew.pivotindex
                mjHighLineBr    := false
                majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)
        if (sizecur - sizepre) == 2
            typelast        = array.last(strARR)
            typepre         = array.get(strARR, array.size(strARR) - 2)
            if (typelast.cond == "High" and typelast.pivotindex >= mjHighLineBrInd) or (typepre.cond == "High" and typepre.pivotindex >= mjHighLineBrInd)
                typeh           = typelast.cond == "High" ? typelast : typepre
                mjHHVal         := typeh.pivot
                mjHHInd         := typeh.pivotindex
                mjHighLineBr    := false
                majornew = major.new("High", mjHHVal, mjHHInd, time[bar_index - mjHHInd])
                array.push(mjARR, majornew)
                f_zigzagmaj(mjARR)

// => BOS Kalite Tespiti ve Kutu Cizimi
// MSS (trend donusu) → sayaclar sifirlanir
// Devam BOS (mjHH/mjLL) → kalite kontrolu yapilir, sayac artar
qualityBOSDetected = false

// MSS: Trend donusu — sayaclari, LTF bayraklari VE oncuculari sifirla
// Kaliteli BOS icin MSS SONRASI taze LTF sinyali gerekli
if mjLong or mjShort
    rawBOSCount      := 0
    qualityBOSCount  := 0
    ltfBullReady     := false
    ltfBearReady     := false
    ltfBullPrecursor := false
    ltfBearPrecursor := false

// Devam BOS'lari say (HH veya LL)
if mjHH or mjLL
    rawBOSCount += 1

// Kaliteli BOS: Devam BOS + LTF iki-asamali onay (likidite + MSS)
// v39: Ready bayragi tuketilmiyor, ama karsilikli ozel (sadece 1 yon aktif)
// Bayrak timeout (30 bar), trend degisimi veya karsi yon sinyalinde sifirlanir
if mjHH and ltfBullReady and bosBoxEnableInput and supportedTF and hasRealLTF
    qualityBOSCount += 1
    qualityBOSDetected := true
    boxL = time[bar_index - mjLLInd]
    box.new(boxL, mjHHVal, time, mjLLVal, xloc = xloc.bar_time, bgcolor = bosBoxFillInput, border_color = bosBoxBorderInput, border_width = 1)
    label.new(int((boxL + time) / 2), mjHHVal, str.tostring(qualityBOSCount) + " BOS", xloc = xloc.bar_time, style = label.style_label_down, color = color.new(color.white, 100), textcolor = bosBoxBorderInput, size = size.tiny)

if mjLL and ltfBearReady and bosBoxEnableInput and supportedTF and hasRealLTF
    qualityBOSCount += 1
    qualityBOSDetected := true
    boxL = time[bar_index - mjHHInd]
    box.new(boxL, mjHHVal, time, mjLLVal, xloc = xloc.bar_time, bgcolor = bosBoxFillInput, border_color = bosBoxBorderInput, border_width = 1)
    label.new(int((boxL + time) / 2), mjLLVal, str.tostring(qualityBOSCount) + " BOS", xloc = xloc.bar_time, style = label.style_label_up, color = color.new(color.white, 100), textcolor = bosBoxBorderInput, size = size.tiny)

// => Alerts
alertcondition(strBearish, "New H")
alertcondition(strBullish, "New L")
alertcondition(strBearish2, "New H and L")
alertcondition(strBullish2, "New L and H")
alertcondition(mjLong, "Major Long")
alertcondition(mjShort, "Major Short")
alertcondition(qualityBOSDetected and qualityBOSCount == bosAlertCountInput, "Kaliteli BOS Limit")

if alertmjLONGbInput and mjLong
    alert(alertmjlongMSGInput, alert.freq_once_per_bar)
if alertmjSHORTbInput and mjShort
    alert(alertmjshortMSGInput, alert.freq_once_per_bar)
if bosAlertEnableInput and qualityBOSDetected and qualityBOSCount == bosAlertCountInput
    alert(bosAlertMsgInput, alert.freq_once_per_bar)

size = array.size(strARR)
if(size>0 and not strzigzagShowUnConfirmedInput)
    item = array.get(strARR,size-1)
    line.set_color(item.lnzigzag,strzigzagCOLORInput)
    line.set_color(strZigzagLine,na)

// => Dashboard Tablosu
if bosDashEnableInput
    dashPos = switch bosDashPosInput
        "Sag Ust" => position.top_right
        "Sol Ust" => position.top_left
        "Sag Alt" => position.bottom_right
        "Sol Alt" => position.bottom_left
    var table dash = table.new(position.top_right, 2, 5, bgcolor = color.new(#333333, 0), border_width = 1, border_color = color.new(#555555, 0))
    if barstate.islast
        // Tablo pozisyonunu guncelle
        table.set_position(dash, dashPos)
        // Satir 0: Ana Trend
        trendText  = mjDir == "Long" ? "BULL (HTF)" : mjDir == "Short" ? "BEAR (HTF)" : "---"
        trendColor = mjDir == "Long" ? color.green : mjDir == "Short" ? color.red : color.gray
        table.cell(dash, 0, 0, "Ana Trend",         text_color = color.white,  text_size = size.small, bgcolor = color.new(#444444, 0))
        table.cell(dash, 1, 0, trendText,            text_color = trendColor,   text_size = size.small, bgcolor = color.new(#333333, 0))
        // Satir 1: Ham HTF BOS Sayisi
        table.cell(dash, 0, 1, "Ham HTF BOS Sayisi", text_color = color.yellow, text_size = size.small, bgcolor = color.new(#444444, 0))
        table.cell(dash, 1, 1, str.tostring(rawBOSCount), text_color = color.yellow, text_size = size.normal, bgcolor = color.new(#333333, 0))
        // Satir 2: Kaliteli HTF BOS
        table.cell(dash, 0, 2, "KALITELI HTF BOS",   text_color = color.white,  text_size = size.small, bgcolor = color.new(#444444, 0))
        table.cell(dash, 1, 2, str.tostring(qualityBOSCount), text_color = color.red, text_size = size.normal, bgcolor = color.new(#333333, 0))
        // Satir 3: Motor Baglantisi
        ltfLabel = supportedTF ? lowerTF : "---"
        htfLabel = timeframe.period
        table.cell(dash, 0, 3, "Motor Baglantisi",   text_color = color.gray,   text_size = size.small, bgcolor = color.new(#444444, 0))
        table.cell(dash, 1, 3, "LTF: " + ltfLabel + " | HTF: " + htfLabel, text_color = color.new(#90CAF9, 0), text_size = size.small, bgcolor = color.new(#333333, 0))
        // Satir 4: Debug — LTF sinyal durumlari
        debugBull = str.tostring(not na(ltfBullCnt) ? ltfBullCnt : 0)
        debugBear = str.tostring(not na(ltfBearCnt) ? ltfBearCnt : 0)
        debugPrec = (ltfBullPrecursor ? "BP" : "-") + " " + (ltfBearPrecursor ? "SP" : "-")
        debugReady = (ltfBullReady ? "BR" : "-") + " " + (ltfBearReady ? "SR" : "-")
        table.cell(dash, 0, 4, "DEBUG LTF",   text_color = color.orange,   text_size = size.tiny, bgcolor = color.new(#444444, 0))
        table.cell(dash, 1, 4, "B:" + debugBull + " S:" + debugBear + " | " + debugPrec + " | " + debugReady, text_color = color.orange, text_size = size.tiny, bgcolor = color.new(#333333, 0))
