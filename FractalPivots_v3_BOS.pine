var string t02__01              = "Pivot Style"
var string t02__02              = "H Outside Line"
var string t02__03              = ""
var string t02__04              = ""
var string t02__05              = ""
var string t02__06              = "L Outside Line"
var string t02__07              = ""
var string t02__08              = ""
var string t02__09              = ""
var string t02__10              = "Zigzag Line  "
var string t02__11              = ""
var string t02__12              = ""
var string t02__13              = ""
